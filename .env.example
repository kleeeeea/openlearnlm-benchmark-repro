# OpenLearnLM Benchmark Environment Variables
# Copy this file to .env and fill in your API keys
#
# cp .env.example .env

# OpenAI API Key (for GPT model evaluation and judge model)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Key (for multi-model access: Claude, Gemini, DeepSeek, etc.)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Upstage API Key (for Solar model evaluation)
# Get your key at: https://console.upstage.ai/
# UPSTAGE_API_KEY=your_upstage_api_key_here
